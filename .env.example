# Supabase 憑證（訪問計數、管理後台使用）
# 在 Supabase Dashboard > Settings > API 中取得
# 若未設定，相關功能將自動停用
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 中央氣象署 API 金鑰（伺服器端，不暴露給前端）
# 部署至 Vercel 時，請在 Settings > Environment Variables 加入 CWA_API_KEY
# 本地開發時也可在 .env 中設定此變數，Vite 開發伺服器會自動代理請求
# 請到 https://opendata.cwa.gov.tw/ 申請 API 金鑰
CWA_API_KEY=

# 下列舊版 VITE_CWA_API_KEY 已棄用，請改用上方的 CWA_API_KEY
